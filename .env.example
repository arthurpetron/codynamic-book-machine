# Environment Configuration Examples
# Copy this file to .env and customize for your environment

# ============================================================================
# SCHEMA SYSTEM CONFIGURATION
# ============================================================================

# Option 1: Use default schema directory with custom registry file
# Useful for: Testing, development, experimenting with different registries
# SCHEMA_REGISTRY_FILE=dev_registry.json
# SCHEMA_REGISTRY_FILE=test_registry.json

# Option 2: Use custom schema directory (keeps default registry filename)
# Useful for: Multi-user systems, custom installations
# SCHEMA_DIR=/opt/codynamic/schemas
# SCHEMA_DIR=$HOME/.codynamic/schemas

# Option 3: Full path to registry (overrides everything)
# Useful for: Production deployments, specific requirements
# SCHEMA_REGISTRY_PATH=/etc/codynamic/production_registry.json

# ============================================================================
# COMMON CONFIGURATIONS
# ============================================================================

# Development (default - no changes needed)
# Uses: ./data/schemas/schema_registry.json
# (Leave all commented out)

# Testing
# SCHEMA_REGISTRY_FILE=test_registry.json

# Production
# SCHEMA_REGISTRY_PATH=/etc/codynamic/production_registry.json
# SCHEMA_DIR=/opt/codynamic/schemas

# ============================================================================
# LLM API KEYS (if needed for outline generation)
# ============================================================================

# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
